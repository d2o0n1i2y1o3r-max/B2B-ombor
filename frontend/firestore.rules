rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
    }
    
    // Warehouses collection
    match /warehouses/{warehouseId} {
      allow read: if true; // Public read access for marketplace
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.ownerId == request.auth.uid || request.auth.token.role == 'admin');
      allow delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || request.auth.token.role == 'admin');
    }
    
    // Booking requests collection
    match /bookingRequests/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow create: if request.auth != null && request.resource.data.tenantId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.landlordId == request.auth.uid || 
        request.auth.token.role == 'admin'
      );
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}
